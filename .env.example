# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# LLM (default: deepseek)
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
# Optional overrides for other providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
KIMI_API_KEY=

# Encryption — symmetric key used to encrypt org-level LLM keys at rest
# (pgcrypto). Must be a 32+ character random string. Generate one with:
#   openssl rand -hex 32
# Rotating this key invalidates every stored org LLM key.
ENCRYPTION_KEY=

# Email alerts
RESEND_API_KEY=
ALERT_FROM_EMAIL=alerts@ragdrift.example

# App
APP_URL=http://localhost:3000
CRON_SECRET=change-me-to-a-random-string
